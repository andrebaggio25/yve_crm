#!/bin/sh
# Depois de cada commit na branch `hom`, envia automaticamente para origin/hom.
# Requer: git config core.hooksPath githooks  (raiz do repo; ja configurado no clone local)
branch=$(git symbolic-ref --short HEAD 2>/dev/null) || exit 0
[ "$branch" = "hom" ] || exit 0
exec git push origin hom
