# Copie para .env ou .env.local e ajuste

APP_NAME=Yve CRM
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/yve_crm
APP_TIMEZONE=Europe/Madrid
# Idioma por defecto (es|en|pt)
APP_LOCALE=es

DB_HOST=localhost
DB_DATABASE=yve_crm
DB_USERNAME=root
DB_PASSWORD=

SESSION_LIFETIME_MINUTES=120
SESSION_COOKIE_SECURE=false

CSRF_TOKEN_NAME=csrf_token
UPLOAD_MAX_BYTES=10485760
ALLOWED_UPLOAD_TYPES=text/csv,application/vnd.ms-excel

# Em producao mantenha false a menos que precise da UI de migrations
ALLOW_MIGRATIONS_WEB=

# SMTP (fila email_outbox + worker)
MAIL_HOST=
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=Yve CRM

# Rate limit login (opcional)
LOGIN_MAX_ATTEMPTS=8
LOGIN_DECAY_MINUTES=15

# Evolution API (VPS) — valores padrao ao criar instancia no CRM
EVOLUTION_API_URL=
EVOLUTION_API_KEY=

# Webhook base n8n (usado em automacoes send_webhook)
N8N_WEBHOOK_URL=
